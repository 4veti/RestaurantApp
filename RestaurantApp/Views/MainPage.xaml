<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:RestaurantApp.ViewModels"
             xmlns:model="clr-namespace:RestaurantApp.Domain.Contracts.DTOs;assembly=RestaurantApp.Domain"
             xmlns:clientModel="clr-namespace:RestaurantApp.Models;assembly=RestaurantApp.Client"
             x:DataType="viewmodel:MainPageViewModel"
             x:Class="RestaurantApp.Views.MainPage"
             Title="Храни"
             BackgroundColor="AliceBlue">

    <Grid>
        <Grid x:Name="mainGrid"
            ColumnDefinitions="0.1*,0.6*,0.3*"
            ColumnSpacing="0"
            RowDefinitions="*,Auto"
            RowSpacing="20">

            <VerticalStackLayout Grid.Column="0"
                                 x:Name="menuStackLayout"
                                 BackgroundColor="AliceBlue"
                                 Margin="0, 1, 0, 0"/>

            <Frame x:Name="mainFrame" 
                   Grid.Column="1"
                   VerticalOptions="StartAndExpand"
                   BorderColor="Transparent"
                   BackgroundColor="AliceBlue">
                <ScrollView x:Name="mainScrollView" Scrolled="OnScrollViewScrolled"/>
            </Frame>

            <VerticalStackLayout Grid.Column="2">
                <CollectionView BackgroundColor="Transparent"
                                x:Name="foodsCollection"
                                Grid.Column="2" Grid.Row="0"
                                ItemsSource="{Binding MyFoods}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="clientModel:FoodItemModel">
                            <Grid Padding="10,0,20,0">
                                <Frame>
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="20">
                                        <Label Grid.Column="0"
                                               VerticalTextAlignment="Center"
                                               FontSize="18"
                                               FontAttributes="Italic">
                                            <Label.Text>
                                                <MultiBinding StringFormat="{}{0} - {2}лв (x{1})">
                                                    <Binding Path="Name"/>
                                                    <Binding Path="Count"/>
                                                    <Binding Path="Price"/>
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>

                                        <HorizontalStackLayout Grid.Column="2"
                                                               MaximumHeightRequest="50"
                                                               Padding="0" Margin="0, -10, 0, -10">
                                            <Button Text="+" FontSize="Large" FontAttributes="Bold"
                                                    BorderWidth="1" BorderColor="Transparent"
                                                    BackgroundColor="Transparent"
                                                    TextColor="Black"
                                                    Pressed="AnimateButtonAsync_Pressed"
                                                    Released="AnimateButtonAsync_Released"
                                                    CommandParameter="{Binding Id}"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainPageViewModel}}, x:DataType=viewmodel:MainPageViewModel, Path=IncreaseFoodItemCountCommand}">
                                            </Button>

                                            <Button Text="-" FontSize="Large" FontAttributes="Bold"
                                                    BorderWidth="1" BorderColor="Transparent"
                                                    BackgroundColor="Transparent"
                                                    TextColor="Black"
                                                    Pressed="AnimateButtonAsync_Pressed"
                                                    Released="AnimateButtonAsync_Released"
                                                    CommandParameter="{Binding Id}"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainPageViewModel}}, x:DataType=viewmodel:MainPageViewModel, Path=DecreaseFoodItemCountCommand}"/>
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Frame>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <CollectionView BackgroundColor="Transparent"
                                Grid.Column="1" Grid.Row="1"
                                ItemsSource="{Binding MyDrinks}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="clientModel:DrinkItemModel">
                            <Grid Padding="10,0,20,0">
                                <Frame>
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="20">
                                        <Label VerticalTextAlignment="Center" Margin="-10"
                                               FontSize="18"
                                               FontAttributes="Italic">
                                            <Label.Text>
                                                <MultiBinding StringFormat="{}{0} - {2}лв (x{1})">
                                                    <Binding Path="Name"/>
                                                    <Binding Path="Count"/>
                                                    <Binding Path="Price"/>
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>

                                        <HorizontalStackLayout Grid.Column="2"
                                                               MaximumHeightRequest="50"
                                                               Padding="0" Margin="0, -10, 0, -10">
                                            <Button Text="+" FontSize="Large" FontAttributes="Bold"
                                                    BorderWidth="1" BorderColor="Transparent"
                                                    BackgroundColor="Transparent"
                                                    TextColor="Black"
                                                    Pressed="AnimateButtonAsync_Pressed"
                                                    Released="AnimateButtonAsync_Released"
                                                    CommandParameter="{Binding Id}"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainPageViewModel}}, x:DataType=viewmodel:MainPageViewModel, Path=IncreaseDrinkItemCountCommand}">
                                            </Button>

                                            <Button Text="-" FontSize="Large" FontAttributes="Bold"
                                                    BorderWidth="1" BorderColor="Transparent"
                                                    BackgroundColor="Transparent"
                                                    TextColor="Black"
                                                    Pressed="AnimateButtonAsync_Pressed"
                                                    Released="AnimateButtonAsync_Released"
                                                    CommandParameter="{Binding Id}"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainPageViewModel}}, x:DataType=viewmodel:MainPageViewModel, Path=DecreaseDrinkItemCountCommand}"/>
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Frame>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Grid ColumnDefinitions="0.5*,0.5*"
                          ColumnSpacing="10"
                          Margin="10, 20, 20, 0">
                    <Label Text="{Binding TotalPrice, StringFormat='Общо: {0}лв'}"
                           Grid.Column="0"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"
                           FontSize="Medium"
                           FontAttributes="Italic,Bold"/>
                    <Button Text="Поръчай!"
                            Grid.Column="1"
                            BackgroundColor="ForestGreen"
                            FontSize="Medium"
                            Clicked="ButtonFinishOrder_Clicked"/>
                </Grid>
            </VerticalStackLayout>

            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               HorizontalOptions="FillAndExpand"
                               VerticalOptions="CenterAndExpand"
                               Grid.RowSpan="2"
                               Grid.ColumnSpan="3"/>

        </Grid>

        <Frame x:Name="fWelcomeScreenShade"
               BackgroundColor="DarkOliveGreen"
               Opacity="0.69"
               VerticalOptions="FillAndExpand"
               HorizontalOptions="FillAndExpand"
               BorderColor="Transparent"/>

        <Frame x:Name="fConfirmPlaceOrder"
               IsVisible="False"
               IsEnabled="False"
               WidthRequest="700"
               HeightRequest="150">
            <Grid ColumnDefinitions="0.5*, 0.5*"
                  RowDefinitions="Auto, Auto"
                  RowSpacing="25"
                  ColumnSpacing="10">
                <Label Grid.ColumnSpan="2"
                       Grid.Row="0"
                       Text="Сигурни ли сте, че искате да завършите поръчката?"
                       FontSize="Medium" FontAttributes="Italic"/>
                <Button Text="Върни се към менюто"
                        Grid.Column="0"
                        Grid.Row="1"
                        BackgroundColor="LightGray"
                        FontSize="Medium"
                        Clicked="ButtonResumeOrder_Clicked"/>
                <Button Text="Поръчай!"
                        Grid.Column="1"
                        Grid.Row="1"
                        BackgroundColor="ForestGreen"
                        FontSize="Medium"
                        Clicked="ButtonResumeOrder_Clicked"
                        Command="{Binding PlaceOrderCommand}"/>
            </Grid>
        </Frame>

        <Grid x:Name="gWelcomeScreen" 
              ColumnDefinitions="0.2*,Auto,0.2*"
              RowDefinitions="0.2*,0.6*,0.2*">
            <VerticalStackLayout Grid.Column="1"
                                 Grid.Row="1"
                                 Spacing="20">
                <Frame BorderColor="Transparent"
                       BackgroundColor="Transparent">
                    <Label HorizontalTextAlignment="Center"
                           FontSize="30"
                           Text="Добре дошли!"/>
                </Frame>
                
                <Button Text="Направи поръчка"
                        FontSize="24"
                        Clicked="ButtonStartOrder_Clicked"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
