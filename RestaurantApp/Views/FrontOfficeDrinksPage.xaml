<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RestaurantApp.Views.FrontOfficeDrinksPage"
             xmlns:viewmodel="clr-namespace:RestaurantApp.ViewModels"
             xmlns:model="clr-namespace:RestaurantApp.Domain.Contracts.DTOs;assembly=RestaurantApp.Domain"
             x:DataType="viewmodel:FrontOfficeViewModel"
             Title="Управление на системата">

    <Grid Background="Beige">
        <Grid ColumnDefinitions="*,Auto,*"
          ColumnSpacing="5"
          RowDefinitions="Auto,*,0.05*"
          RowSpacing="0">

            <Button Text="Добави напитка"
                    Grid.Column="1"
                    Grid.Row="0"
                    Margin="5,5,5,10"
                    Clicked="AddDrinkButton_Clicked"/>

            <Frame Grid.Column="1"
                   Grid.Row="1"
                   CornerRadius="30"
                   BackgroundColor="CornflowerBlue">
                <ScrollView>
                    <CollectionView x:Name="drinksCollection"
                                BackgroundColor="Transparent"
                                MinimumWidthRequest="500"
                                ItemsSource="{Binding DrinksList}"
                                SelectionMode="Single">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="model:DrinkDto">
                                <Grid Padding="10">
                                    <Frame>
                                        <VerticalStackLayout>
                                            <Label FontSize="22" Text="{Binding Name}"/>
                                            <Label Text="{Binding Millilitres, StringFormat='{0}мл'}"/>
                                            <Label Text="{Binding DrinkType}"/>
                                            <Label Text="{Binding Price, StringFormat='Цена: {0:C2}'}"/>
                                            <Label IsVisible="{Binding IsAlcoholic}" Text="{Binding AlcoholPercentage, StringFormat='Алк. {0:F2}%'}"/>
                                        </VerticalStackLayout>
                                    </Frame>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </ScrollView>
            </Frame>

            <ActivityIndicator IsVisible="{Binding IsDrinksBusy}"
                       IsRunning="{Binding IsDrinksBusy}"
                       Grid.RowSpan="2"
                       Grid.ColumnSpan="3"/>

        </Grid>

        <Frame x:Name="backgroundDim"
               BackgroundColor="Gray"
               Opacity="0.8"
               IsEnabled="False"
               IsVisible="False">
        </Frame>

        <Grid x:Name="gridDrinkForm"
              IsVisible="False"
              ColumnDefinitions="*,*,*"
              RowDefinitions="*,Auto,*,*,*">
            <Frame BackgroundColor="AliceBlue"
                   Grid.Column="1"
                   Grid.Row="1">
                <VerticalStackLayout>
                    <Label Text="Име:" Margin="0, 0, 0, 5"/>
                    <Entry x:Name="formDrinkName" Margin="0, 0, 0, 10" Placeholder="..." Text="{Binding SelectedDrink.Name}" BackgroundColor="White" Keyboard="Text"/>

                    <Label Text="Милилитри:" Margin="0, 0, 0, 5"/>
                    <Entry x:Name="formDrinkGrams" Margin="0, 0, 0, 10" Placeholder="000" Text="{Binding SelectedDrink.Millilitres, Converter={StaticResource integerConverter}}" BackgroundColor="White" Keyboard="Numeric"/>

                    <Label Text="Алкохолна напитка"/>
                    <CheckBox x:Name="chIsAlcoholicBevarage" IsChecked="{Binding SelectedDrink.IsAlcoholic}" CheckedChanged="chIsAlcoholicBevarage_CheckedChanged"/>

                    <Label x:Name="lbAlcPercentage" Text="Алк. процент:" Margin="0, 0, 0, 5" IsVisible="False"/>
                    <Entry x:Name="formDrinkAlcoholPercentage" Margin="0, 0, 0, 10" IsVisible="False" Placeholder="0.00" Text="{Binding SelectedDrink.AlcoholPercentage, Converter={StaticResource decimalConverter}}" BackgroundColor="White" Keyboard="Numeric"/>

                    <Label Text="Цена:" Margin="0, 0, 0, 5"/>
                    <Entry x:Name="formDrinkPrice" Margin="0, 0, 0, 10" Placeholder="0.00" Text="{Binding SelectedDrink.Price, Converter={StaticResource decimalConverter}}" BackgroundColor="White" Keyboard="Numeric"/>

                    <Label Text="Тип:" Margin="0, 0, 0, 5"/>
                    <Picker x:Name="formDrinkTypePicker"
                            Margin="0, 0, 0, 10"
                            BackgroundColor="White"
                            SelectedIndexChanged="formDrinkTypePicker_SelectedIndexChanged"
                            ItemsSource="{Binding DrinkTypesList}"
                            SelectedItem="{Binding SelectedDrinkType}"
                            ItemDisplayBinding="{Binding Name}"/>
                    <HorizontalStackLayout Margin="0,15,0,0"
                                           HorizontalOptions="CenterAndExpand">
                        <Button Text="Откажи"
                                Clicked="CancelButton_Clicked"
                                MaximumWidthRequest="250"
                                MinimumWidthRequest="200"
                                BackgroundColor="Gray"
                                Margin="0, 0, 10, 0"/>
                        <Button Text="Запази"
                                Clicked="SaveButton_Clicked"
                                MaximumWidthRequest="250"
                                MinimumWidthRequest="200"
                                BackgroundColor="ForestGreen"
                                CommandParameter="{Binding SelectedDrink}"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:FrontOfficeViewModel}}, x:DataType=viewmodel:FrontOfficeViewModel, Path=UpdateDrinkCommand}"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>